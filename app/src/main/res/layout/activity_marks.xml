<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="18dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardMarksEntry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="18dp"
        app:cardElevation="3dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Subject"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerMarkSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:background="@drawable/bg_spinner_surface" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="Assessment Type"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerAssessmentType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:background="@drawable/bg_spinner_surface" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="Marks Obtained"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etMarksValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                style="@style/Widget.AcadMate.Input"
                android:hint="Marks Obtained"
                android:inputType="numberDecimal" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveMarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="Save Marks"
                android:textAllCaps="false"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="12dp"
                app:rippleColor="@color/brand_primary_dark" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <EditText
        android:id="@+id/etSearchMarks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        style="@style/Widget.AcadMate.Input"
        android:hint="Search subject marks..." />

    <ListView
        android:id="@+id/listMarks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        android:layout_weight="1"
        android:layoutAnimation="@anim/layout_staggered_in"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

</LinearLayout>
