<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="18dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardAttendanceEntry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="18dp"
        app:cardElevation="3dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Subject"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerAttendanceSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:background="@drawable/bg_spinner_surface" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="Total Classes"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTotalClasses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                style="@style/Widget.AcadMate.Input"
                android:hint="Total Classes"
                android:inputType="number" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="Attended Classes"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etAttendedClasses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                style="@style/Widget.AcadMate.Input"
                android:hint="Attended Classes"
                android:inputType="number" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMarkPresent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Present +1"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/bg_surface"
                    app:cornerRadius="10dp"
                    android:textColor="@color/text_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMarkAbsent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Absent +1"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/bg_surface"
                    app:cornerRadius="10dp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveAttendance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="Post Attendance (Teacher)"
                android:textAllCaps="false"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="12dp"
                app:rippleColor="@color/brand_primary_dark" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLockTeacherMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:text="Lock Teacher Mode"
                android:textAllCaps="false"
                android:visibility="gone"
                app:backgroundTint="@color/border_soft"
                app:cornerRadius="12dp"
                app:rippleColor="@color/brand_primary_dark"
                android:textColor="@color/text_primary" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <EditText
        android:id="@+id/etSearchAttendance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        style="@style/Widget.AcadMate.Input"
        android:hint="Search attendance subject..." />

    <Spinner
        android:id="@+id/spinnerAttendanceFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="@drawable/bg_spinner_surface" />

    <ListView
        android:id="@+id/listAttendance"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        android:layout_weight="1"
        android:layoutAnimation="@anim/layout_staggered_in"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

</LinearLayout>
