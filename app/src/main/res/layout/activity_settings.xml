<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="18dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="18dp"
        app:cardElevation="3dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Teacher Name"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTeacherName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                style="@style/Widget.AcadMate.Input"
                android:hint="Enter teacher name" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:text="SMS Notification Number"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPhoneNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                style="@style/Widget.AcadMate.Input"
                android:hint="Enter phone number"
                android:inputType="phone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:text="Teacher PIN (required to post attendance)"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTeacherPin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:layout_marginBottom="25dp"
                style="@style/Widget.AcadMate.Input"
                android:hint="Set 4+ digit PIN"
                android:inputType="numberPassword" />

            <CheckBox
                android:id="@+id/cbEnableAssignmentNotifs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable assignment notifications"
                android:textColor="@color/text_primary" />

            <CheckBox
                android:id="@+id/cbEnableLowAttendanceSms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable low attendance SMS alerts"
                android:textColor="@color/text_primary" />

            <CheckBox
                android:id="@+id/cbEnableSummaryNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable daily summary notifications"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSavePhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="Save Settings"
                android:textAllCaps="false"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="12dp"
                app:rippleColor="@color/brand_primary_dark" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="Logout"
                android:textAllCaps="false"
                app:backgroundTint="@color/border_soft"
                android:textColor="@color/text_primary"
                app:cornerRadius="12dp"
                app:rippleColor="@color/brand_primary_dark" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
